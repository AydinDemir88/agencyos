# =============================================================================
# AgencyOS — Environment Variables
# =============================================================================
# NEVER commit a populated .env file.
# Copy this file to .env and fill in real values locally / in your secrets manager.
# All secrets should be injected via your CI/CD platform (GitHub Actions secrets,
# AWS SSM Parameter Store, HashiCorp Vault, etc.) — never hardcoded.
# =============================================================================

# --- Application ---
NODE_ENV=development                  # development | staging | production
PORT=3000
API_BASE_URL=http://localhost:3000

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_URL=postgresql://agencyos_app:CHANGE_ME@localhost:5432/agencyos
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                          # Set true in production; provide certs below
# DB_SSL_CA=/path/to/ca.pem
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# --- Auth ---
JWT_SECRET=CHANGE_ME_min_32_chars_random_string
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
BCRYPT_COST=12

# --- Encryption (AES-256-GCM) ---
# 32-byte hex-encoded master key for encrypting credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# Optional: KMS key alias/ARN when using AWS KMS envelope encryption
# KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:alias/agencyos-master

# --- Redis (rate limiting & session cache) ---
REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_MS=900000           # 15 minutes
RATE_LIMIT_MAX_ATTEMPTS=5

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=info                        # error | warn | info | debug

# --- NDC ---
NDC_DEFAULT_VERSION=21.3
NDC_REQUEST_TIMEOUT_MS=10000

# =============================================================================
# SECURITY REMINDERS
# =============================================================================
# • MASTER_ENCRYPTION_KEY — never log, never return in API responses
# • JWT_SECRET            — never log, never return in API responses
# • DB_URL                — never log, never return in API responses
# • Rotate MASTER_ENCRYPTION_KEY requires re-encrypting all BYTEA columns
# =============================================================================
